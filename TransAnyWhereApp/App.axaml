<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="TransAnyWhereApp.App"
			 RequestedThemeVariant="Default">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://TransAnyWhereApp/Assets/i18n.zh.axaml"/>
				<ResourceInclude Source="avares://TransAnyWhereApp/Assets/i18n.en.axaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>

	<Application.Styles>
		<FluentTheme />
		<StyleInclude Source="avares://TransAnyWhereApp/Assets/StyleResources.axaml"/>
		<StyleInclude Source="avares://TransAnyWhereApp/Assets/TextBoxStyles.axaml"/>
		<StyleInclude Source="avares://TransAnyWhereApp/Assets/ButtonStyles.axaml"/>
		<StyleInclude Source="avares://TransAnyWhereApp/Assets/CardStyles.axaml"/>
		<StyleInclude Source="avares://TransAnyWhereApp/Assets/CheckBoxStyles.axaml"/>
	</Application.Styles>
</Application>