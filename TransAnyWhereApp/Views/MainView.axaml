<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:dialogs="using:Avalonia.Dialogs"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 xmlns:views="clr-namespace:TransAnyWhereApp.Views"
			 x:Class="TransAnyWhereApp.Views.MainView"
			 x:DataType="vm:MainViewModel"
			 DragDrop.AllowDrop="True"
			 Background="#121212">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="20" Spacing="20">

				<views:QRCodeButtonView />

				<views:ToolButtonView/>

				<views:TransferManagerView />

				<views:DownloadSettingView />

			</StackPanel>

		</ScrollViewer>

		<views:QRCodeView />

		<views:AlertToastView/>

		<views:ConnectionApplicationView/>

	</Grid>
</UserControl>