<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.ConnectionApplicationView"
			 x:DataType="vm:MainViewModel" >
	<Grid Background="#CC000000" IsVisible="{Binding IsConfirmVisible}" ZIndex="2000">
		<Border Background="#252525"
				CornerRadius="15"
				Padding="25"
				VerticalAlignment="Center"
				HorizontalAlignment="Center"
				Width="320"
				BoxShadow="0 10 30 0 #AA000000">
			<StackPanel Spacing="20">
				<StackPanel Spacing="10" HorizontalAlignment="Center">
					<TextBlock Text="{DynamicResource U_Title_ConnRequest}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
					<TextBlock Text="📱" FontSize="40" HorizontalAlignment="Center" Margin="0,10"/>
					<TextBlock Text="{Binding ConnectionRequestText}"
							   TextWrapping="Wrap"
							   TextAlignment="Center"
							   Foreground="#BBB"/>
				</StackPanel>

				<Grid ColumnDefinitions="*, *" ColumnSpacing="15">
					<Button Grid.Column="0"
							Content="{DynamicResource U_Btn_Reject}"
							Classes="ToolButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							Command="{Binding RejectConnectionCommand}"/>

					<Button Grid.Column="1"
							Content="{DynamicResource U_Btn_Accept}"
							Classes="Primary"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							Command="{Binding AcceptConnectionCommand}"/>
				</Grid>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
