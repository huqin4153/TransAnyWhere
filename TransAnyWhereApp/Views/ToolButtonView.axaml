<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.ToolButtonView"
			 x:DataType="vm:MainViewModel" >
	<Border Background="#1E1E1E" CornerRadius="10" Padding="5">
		<UniformGrid Columns="4" Width="500" HorizontalAlignment="Center">
			<Button Classes="ToolButton" Command="{Binding SelectFilesCommand}" Background="Transparent">
				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
					<TextBlock Text="＋" Foreground="#4CD964" VerticalAlignment="Center"/>
					<TextBlock Text="{DynamicResource U_Btn_AddFiles}" VerticalAlignment="Center"/>
				</StackPanel>
			</Button>
			 
			<Button Classes="ToolButton" Command="{Binding StartSyncCommand}" Background="Transparent">
				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
					<TextBlock Text="▶" Foreground="#4CD964" VerticalAlignment="Center"/>
					<TextBlock Text="{DynamicResource U_Btn_StartAll}" VerticalAlignment="Center"/>
				</StackPanel>
			</Button>
			 
			<Button Classes="ToolButton" Command="{Binding ClearDoneCommand}" Background="Transparent">
				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
					<TextBlock Text="🗑" Foreground="#FF3B30" VerticalAlignment="Center"/>
					<TextBlock Text="{DynamicResource U_Btn_ClearDone}" VerticalAlignment="Center"/>
				</StackPanel>
			</Button>
		</UniformGrid>
	</Border>
</UserControl>
