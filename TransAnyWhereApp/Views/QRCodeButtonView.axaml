<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.QRCodeButtonView"
			 x:DataType="vm:MainViewModel">

	<Border Background="#12FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Padding="15,8">
		<Grid ColumnDefinitions="Auto, Auto, *">

			<Button Classes="LinkButton"
					Command="{Binding ShowQrCommand}" 
					VerticalAlignment="Center">
				<StackPanel Orientation="Horizontal" Spacing="6">
					<TextBlock Text="🔳" FontSize="14" VerticalAlignment="Center"/>
					<TextBlock VerticalAlignment="Center" Text="{DynamicResource U_Btn_ConnQR}" FontSize="13" Foreground="White"/>
				</StackPanel>
			</Button>

			<Rectangle Grid.Column="1" Width="1" Height="14" Fill="#30FFFFFF" Margin="15,0" VerticalAlignment="Center"/>

			<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
				<TextBlock Text="{DynamicResource U_Label_Connected}" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="0,0,5,0"/>

				<ItemsControl ItemsSource="{Binding ConnectedClients}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="12"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="#154CD964" CornerRadius="4" Padding="8,4">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<Ellipse Width="6" Height="6" Fill="#4CD964" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding DeviceName}" FontSize="12" VerticalAlignment="Center"/>
									<Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).DisconnectClientCommand}"
											CommandParameter="{Binding}"
											Background="Transparent" BorderThickness="0" Padding="2" Margin="4,0,0,0">
										<TextBlock Text="×" FontSize="14" Foreground="#FF453A" Opacity="0.6"/>
									</Button>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>

		</Grid>
	</Border>
</UserControl>
