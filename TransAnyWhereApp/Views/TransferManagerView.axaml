<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.TransferManagerView"
			 x:DataType="vm:MainViewModel">
	<UserControl.Styles>
		<Style Selector="Button.LinkButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#4CD964"/>
			<Setter Property="Padding" Value="5,2"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.LinkButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#204CD964"/>
			<Setter Property="Foreground" Value="#65EB7D"/>
		</Style>
		<Style Selector="CheckBox">
			<Setter Property="Foreground" Value="#4CD964"/>
		</Style>

		<Style Selector="CheckBox:pointerover /template/ ContentPresenter">
			<Setter Property="Foreground" Value="#65EB7D"/> <Setter Property="Background" Value="Transparent"/> </Style>

		<Style Selector="CheckBox:pressed /template/ ContentPresenter">
			<Setter Property="Foreground" Value="#4CD964"/>
		</Style>

		<Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
			<Setter Property="BorderBrush" Value="#4CD964"/>
		</Style>
	</UserControl.Styles>
	<Grid RowDefinitions="*, Auto, *">

		<Grid Grid.Row="0" RowDefinitions="Auto, Auto, *">
			<Border Background="#10FFFFFF" Padding="12,8">
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBlock Text="{DynamicResource U_Title_SendQueue}" FontSize="12" FontWeight="Bold" Foreground="#4CD964" VerticalAlignment="Center"/>
					<Border Background="#4CD964" CornerRadius="10" Padding="6,1" IsVisible="{Binding Files.Count}">
						<TextBlock Text="{Binding Files.Count}" FontSize="10" Foreground="White"/>
					</Border>
				</StackPanel>
			</Border>

			<Border Grid.Row="1" Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Padding="12,6">
				<StackPanel Orientation="Horizontal" Spacing="15">
					<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
						<TextBlock Text="🎯" FontSize="12" VerticalAlignment="Center"/>
						<TextBlock Text="{DynamicResource U_Label_Target}" VerticalAlignment="Center" FontSize="11" Foreground="#99FFFFFF"/>
					</StackPanel>

					<ItemsControl ItemsSource="{Binding ConnectedClients}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="12"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<CheckBox IsChecked="{Binding IsSelected}"
										  Content="{Binding DeviceName}"
										  FontSize="12"
										  Foreground="#4CD964"
										  MinWidth="60"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<Rectangle Width="1" Height="14" Fill="#30FFFFFF" VerticalAlignment="Center" Margin="5,0"/>

					<Button Content="{DynamicResource U_Btn_SelectAllToggle}"
							Classes="LinkButton"
							Command="{Binding SelectAllDevicesCommand}"
							VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<Panel Grid.Row="2" Name="DropZone" DragDrop.AllowDrop="True" Background="Transparent">
				<ListBox Background="Transparent" ItemsSource="{Binding Files}" BorderThickness="0">
					<ListBox.Styles>
						<Style Selector="ListBoxItem">
							<Setter Property="Padding" Value="0"/>
							<Setter Property="MinHeight" Value="0"/>
						</Style>
					</ListBox.Styles>

					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="models:TransferTask">
							<Border Padding="12,8" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1">
								<Grid ColumnDefinitions="*, Auto, Auto">
									<TextBlock Text="{Binding FileName}"
											   FontSize="14" FontWeight="Medium"
											   VerticalAlignment="Center"
											   TextTrimming="CharacterEllipsis"/>

									<TextBlock Grid.Column="1" Text="{Binding StatusText}"
											   Foreground="#888" FontSize="12"
											   Margin="15,0" VerticalAlignment="Center"/>

									<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
										<Button Classes="ToolButton"
												Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).ToggleFileStatusCommand}"
												CommandParameter="{Binding}">
											<TextBlock Text="{Binding StatusIcon}" Foreground="#4CD964"/>
										</Button>
										<Button Classes="ToolButton"
												Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).RemoveFileCommand}"
												CommandParameter="{Binding}">
											<TextBlock Text="🗑" Foreground="#FF3B30"/>
										</Button>
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" IsVisible="{Binding ShowEmptyHint}" Opacity="0.15">
					<TextBlock Text="📤" FontSize="40" HorizontalAlignment="Center"/>
					<TextBlock Text="{DynamicResource U_Hint_DragDrop}" FontSize="12" HorizontalAlignment="Center"/>
				</StackPanel>
			</Panel>
		</Grid>

		<GridSplitter Grid.Row="1" Height="2" Background="#20FFFFFF" ResizeDirection="Rows"/>

		<Grid Grid.Row="2" RowDefinitions="Auto, *" Background="#08000000">
			<Border Background="#10FFFFFF" Padding="12,8">
				<StackPanel Orientation="Horizontal" Spacing="10">
					<TextBlock Text="{DynamicResource U_Title_ReceiveRecord}" FontSize="12" FontWeight="Bold" Foreground="#007AFF" VerticalAlignment="Center"/>
					<Border Background="#007AFF" CornerRadius="10" Padding="6,1" IsVisible="{Binding ReceivedFiles.Count}">
						<TextBlock Text="{Binding ReceivedFiles.Count}" FontSize="10" Foreground="White"/>
					</Border>
				</StackPanel>
			</Border>

			<Panel Grid.Row="1">
				<ListBox Background="Transparent" ItemsSource="{Binding ReceivedFiles}" BorderThickness="0">
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="models:TransferTask">
							<Border Padding="12,15" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1">
								<StackPanel Spacing="10">
									<Grid ColumnDefinitions="Auto, *, Auto, Auto">
										<TextBlock Text="{Binding DeviceName, StringFormat='[{0}]'}" Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="#007AFF" FontSize="12" VerticalAlignment="Center" Margin="15,0"/>
										<StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
											<Button Classes="ToolButton" Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).OpenDownloadFolderCommand}" Width="30" Height="30">
												<TextBlock Text="📁" FontSize="14"/>
											</Button>
											<Button Classes="ToolButton" Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).RemoveReceivedRecordCommand}" CommandParameter="{Binding}" Width="30" Height="30">
												<TextBlock Text="🗑" FontSize="14" Foreground="#FF3B30"/>
											</Button>
										</StackPanel>
									</Grid>
									<Grid ColumnDefinitions="*, Auto">
										<ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Foreground="#007AFF" Background="#20000000" CornerRadius="2" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0:F0}%}" FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center" Width="30" TextAlignment="Right"/>
									</Grid>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" IsVisible="{Binding ShowReceivedEmptyHint}" Opacity="0.15">
					<TextBlock Text="📥" FontSize="40" HorizontalAlignment="Center"/>
					<TextBlock Text="{DynamicResource U_Hint_NoReceive}" FontSize="12" HorizontalAlignment="Center"/>
				</StackPanel>
			</Panel>
		</Grid>
	</Grid>
</UserControl>