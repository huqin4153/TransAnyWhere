<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels" 
			 x:Class="TransAnyWhereApp.Views.AlertToastView"
			 x:DataType="vm:MainViewModel" >
	<Border VerticalAlignment="Top"
			HorizontalAlignment="Center"
			Margin="0,30,0,0"
			Background="#2D2D2D"
			BorderBrush="#3F3F3F"
			BorderThickness="1"
			CornerRadius="20"
			Padding="20,10"
			ZIndex="1000"
			IsVisible="{Binding IsAlertVisible}"
			BoxShadow="0 4 15 0 #80000000">

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="💡" VerticalAlignment="Center"/>
			<TextBlock Text="{Binding AlertMessage}"
					   Foreground="White"
					   VerticalAlignment="Center"
					   FontWeight="Medium"/>
		</StackPanel>

		<Border.Transitions>
			<Transitions>
				<DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
			</Transitions>
		</Border.Transitions>
	</Border>
</UserControl>
