<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.SelectFileButton"
			 x:DataType="vm:MainViewModel" >
	<Button Content="{DynamicResource U_Btn_SelectFilesMain}"
			Classes="Primary"
			HorizontalAlignment="Stretch"
			HorizontalContentAlignment="Center"
			Command="{Binding SelectFilesCommand}"/>
</UserControl>
