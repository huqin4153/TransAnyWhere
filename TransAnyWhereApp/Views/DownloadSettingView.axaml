<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:models="using:TransAnyWhereApp.Models"
			 xmlns:vm="using:TransAnyWhereApp.ViewModels"
			 x:Class="TransAnyWhereApp.Views.DownloadSettingView"
			 x:DataType="vm:MainViewModel" >
	
	<Border Padding="12,10" Background="#05FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0">
		<StackPanel Spacing="6">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<TextBlock Text="{DynamicResource U_Label_DownloadDir}" FontSize="12" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
				<TextBlock Text="{DynamicResource U_Hint_StoragePos}" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
			</StackPanel>

			<Grid ColumnDefinitions="*, Auto">
				<Border Grid.Column="0" 
						Background="#15FFFFFF" 
						CornerRadius="4" 
						Padding="10,6"
						BorderBrush="#20FFFFFF"
						BorderThickness="1">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="📂" FontSize="12" VerticalAlignment="Center" Opacity="0.7"/>
						<TextBlock Text="{Binding DownloadPath}" 
								   FontSize="11" 
								   VerticalAlignment="Center" 
								   Foreground="#BBFFFFFF"
								   TextTrimming="CharacterEllipsis"/>
					</StackPanel>
				</Border>

				<Button Grid.Column="1"
						Classes="LinkButton"
						Command="{Binding SelectDownloadFolderCommand}"
						Margin="10,0,0,0"
						Padding="10,4">
					<TextBlock Text="{DynamicResource U_Btn_Browse}" FontSize="12" VerticalAlignment="Center"/>
				</Button>
			</Grid>
		</StackPanel>
	</Border>
</UserControl>